# Example environment variables for backend
# Copy this to `.env` and replace placeholders with real credentials.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
DNS_SERVERS=8.8.8.8,8.8.4.4
PORT=5000
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:5173
# MongoDB Atlas URI
# Use your MongoDB connection string from mongodb.com
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/UAQTEA?appName=Cluster

# Port (Render will automatically assign this, or use custom port)
# Leave as default or set in Render dashboard
PORT=5000

# JWT Secret for authentication
# IMPORTANT: Generate a strong random string for production
# Never commit actual secrets - use environment variables in deployment platform
JWT_SECRET=your-secure-jwt-secret-key-here

# Frontend URL (for CORS)
# Development: http://localhost:5173
# Production (Vercel): https://your-frontend-domain.vercel.app
FRONTEND_URL=http://localhost:5173

# Node Environment
# Set to 'production' when deploying to Render
NODE_ENV=development

# Vercel Frontend URL (when deployed)
# Only needed if using VERCEL domain for frontend
# VERCEL_URL=your-frontend-domain.vercel.app
